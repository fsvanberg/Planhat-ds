{
  "name": "planhat-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "figma:discover": "dotenv -e .env.local -- npx tsx scripts/figma-sync.mts --discover",
    "figma:generate": "dotenv -e .env.local -- npx tsx scripts/figma-sync.mts --generate",
    "figma:tokens": "dotenv -e .env.local -- npx tsx scripts/figma-sync.mts --tokens",
    "figma:publish": "dotenv -e .env.local -- npx tsx scripts/figma-sync.mts --publish",
    "figma:sync": "dotenv -e .env.local -- npx tsx scripts/figma-sync.mts --all",
    "tokens:build": "node style-dictionary.config.mjs",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.7.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.1",
    "@figma/code-connect": "^1.4.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.17",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "shadcn": "^4.0.6",
    "storybook": "^10.2.17",
    "style-dictionary": "^5.3.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
