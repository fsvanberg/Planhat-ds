{
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": ["primitive", "semantic"]
  },
  "primitive": {
    "color": {
      "neutral": {
        "50":  { "$value": "#fafafa", "$type": "color" },
        "100": { "$value": "#f5f5f5", "$type": "color" },
        "200": { "$value": "#e5e5e5", "$type": "color" },
        "300": { "$value": "#d4d4d4", "$type": "color" },
        "400": { "$value": "#a3a3a3", "$type": "color" },
        "500": { "$value": "#737373", "$type": "color" },
        "600": { "$value": "#525252", "$type": "color" },
        "700": { "$value": "#404040", "$type": "color" },
        "800": { "$value": "#262626", "$type": "color" },
        "900": { "$value": "#171717", "$type": "color" },
        "950": { "$value": "#0a0a0a", "$type": "color" }
      },
      "red": {
        "500": { "$value": "#ef4444", "$type": "color" },
        "600": { "$value": "#dc2626", "$type": "color" }
      },
      "orange": {
        "50":  { "$value": "#fff7ed", "$type": "color" },
        "100": { "$value": "#ffedd5", "$type": "color" },
        "200": { "$value": "#fed7aa", "$type": "color" },
        "300": { "$value": "#fdba74", "$type": "color" },
        "400": { "$value": "#fb923c", "$type": "color" },
        "500": { "$value": "#f97316", "$type": "color" },
        "600": { "$value": "#ea580c", "$type": "color" },
        "700": { "$value": "#c2410c", "$type": "color" },
        "800": { "$value": "#9a3412", "$type": "color" },
        "900": { "$value": "#7c2d12", "$type": "color" },
        "950": { "$value": "#431407", "$type": "color" }
      },
      "white": { "$value": "#ffffff", "$type": "color" },
      "transparent": { "$value": "#ffffff00", "$type": "color" }
    },
    "radius": {
      "sm":  { "$value": "6px",  "$type": "dimension" },
      "md":  { "$value": "8px",  "$type": "dimension" },
      "lg":  { "$value": "10px", "$type": "dimension" },
      "xl":  { "$value": "14px", "$type": "dimension" },
      "full": { "$value": "9999px", "$type": "dimension" }
    },
    "height": {
      "h-4": { "$value": "16px", "$type": "dimension" },
      "h-5": { "$value": "20px", "$type": "dimension" },
      "h-6": { "$value": "24px", "$type": "dimension" },
      "h-7": { "$value": "28px", "$type": "dimension" },
      "h-8": { "$value": "32px", "$type": "dimension" },
      "h-9": { "$value": "36px", "$type": "dimension" },
      "h-10": { "$value": "40px", "$type": "dimension" },
      "h-12": { "$value": "48px", "$type": "dimension" }
    },
    "font": {
      "family": { "$value": "Inter Variable, sans-serif", "$type": "fontFamily" },
      "weight": {
        "regular": { "$value": "400", "$type": "fontWeight" },
        "medium":  { "$value": "500", "$type": "fontWeight" },
        "semibold": { "$value": "600", "$type": "fontWeight" }
      },
      "size": {
        "xs":   { "$value": "12px", "$type": "dimension" },
        "sm":   { "$value": "13px", "$type": "dimension" },
        "base": { "$value": "14px", "$type": "dimension" },
        "lg":   { "$value": "16px", "$type": "dimension" },
        "xl":   { "$value": "18px", "$type": "dimension" }
      },
      "line-height": {
        "tight":  { "$value": "1", "$type": "number" },
        "snug":   { "$value": "1.25", "$type": "number" },
        "normal": { "$value": "1.5", "$type": "number" }
      }
    },
    "spacing": {
      "1":   { "$value": "4px",  "$type": "dimension" },
      "1.5": { "$value": "6px",  "$type": "dimension" },
      "2":   { "$value": "8px",  "$type": "dimension" },
      "2.5": { "$value": "10px", "$type": "dimension" },
      "3":   { "$value": "12px", "$type": "dimension" },
      "4":   { "$value": "16px", "$type": "dimension" },
      "5":   { "$value": "20px", "$type": "dimension" },
      "6":   { "$value": "24px", "$type": "dimension" }
    }
  },
  "semantic": {
    "color": {
      "background":          { "$value": "{primitive.color.neutral.50}",  "$type": "color" },
      "foreground":          { "$value": "{primitive.color.neutral.950}", "$type": "color" },
      "card":                { "$value": "{primitive.color.white}",       "$type": "color" },
      "card-foreground":     { "$value": "{primitive.color.neutral.950}", "$type": "color" },
      "popover":             { "$value": "{primitive.color.white}",       "$type": "color" },
      "popover-foreground":  { "$value": "{primitive.color.neutral.950}", "$type": "color" },
      "primary":             { "$value": "{primitive.color.orange.600}", "$type": "color" },
      "primary-foreground":  { "$value": "{primitive.color.white}",       "$type": "color" },
      "secondary":           { "$value": "{primitive.color.neutral.100}", "$type": "color" },
      "secondary-foreground":{ "$value": "{primitive.color.neutral.900}", "$type": "color" },
      "muted":               { "$value": "{primitive.color.neutral.100}", "$type": "color" },
      "muted-foreground":    { "$value": "{primitive.color.neutral.500}", "$type": "color" },
      "accent":              { "$value": "{primitive.color.orange.100}", "$type": "color" },
      "accent-foreground":   { "$value": "{primitive.color.orange.900}", "$type": "color" },
      "destructive":         { "$value": "{primitive.color.red.600}",     "$type": "color" },
      "border":              { "$value": "{primitive.color.neutral.200}", "$type": "color" },
      "input":               { "$value": "{primitive.color.neutral.200}", "$type": "color" },
      "ring":                { "$value": "{primitive.color.neutral.400}", "$type": "color" }
    },
    "radius": {
      "default": { "$value": "{primitive.radius.lg}", "$type": "dimension" }
    }
  }
}
